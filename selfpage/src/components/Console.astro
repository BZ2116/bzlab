---
interface Props {
  focus: string;
  track: string;
  work: string;
}

const { focus, track, work } = Astro.props;
---

<div class="w-full max-w-2xl mx-auto">
  <!-- Console window -->
  <div class="rounded-xl border border-white/[0.08] overflow-hidden bg-bg-2/60">
    <!-- Title bar -->
    <div class="flex items-center gap-2 px-4 py-2.5 bg-bg-3/60 border-b border-white/[0.06]">
      <div class="flex gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></span>
      </div>
      <span class="text-[10px] text-muted font-mono ml-2">research-console — bash</span>
    </div>
    <!-- Console body -->
    <div class="p-5 sm:p-6 space-y-3 font-mono text-sm">
      <div class="flex items-start gap-2">
        <span class="text-accent shrink-0">→</span>
        <div>
          <span class="text-muted text-xs">Current Focus</span>
          <p class="text-text mt-0.5">{focus}</p>
        </div>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-accent shrink-0">→</span>
        <div>
          <span class="text-muted text-xs">Research Track</span>
          <p class="text-text mt-0.5">{track}</p>
        </div>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-accent shrink-0">→</span>
        <div>
          <span class="text-muted text-xs">Selected Work</span>
          <p class="text-text mt-0.5">{work}</p>
        </div>
      </div>
    </div>
  </div>
</div>
