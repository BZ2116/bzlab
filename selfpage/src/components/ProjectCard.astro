---
interface Props {
  slug: string;
  name: string;
  fullName: string;
  type: string;
  description: string;
  tech: string[];
  status: string;
}

const { slug, name, fullName, type, description, tech, status } = Astro.props;

const statusMap: Record<string, { label: string; cls: string }> = {
  active: { label: 'Active', cls: 'text-success bg-success/10 border-success/30' },
  published: { label: 'Published', cls: 'text-accent bg-accent/10 border-accent/30' },
  completed: { label: 'Completed', cls: 'text-muted bg-muted/10 border-muted/30' },
};
const s = statusMap[status] || statusMap.completed;
const typeColor = type === 'research' ? '#00d4ff' : '#7b61ff';
---

<a
  href={`/projects/${slug}`}
  class="group block p-5 rounded-xl bg-bg-2/40 border border-white/[0.06] hover:border-white/[0.12] hover:bg-bg-2/70 transition-all duration-200"
>
  <div class="flex items-start justify-between gap-3 mb-3">
    <div class="flex items-center gap-2">
      <div class="w-2 h-2 rounded-full" style={{ backgroundColor: typeColor }}></div>
      <h3 class="font-orbitron text-sm text-text group-hover:text-accent transition-colors">{name}</h3>
    </div>
    <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-mono border ${s.cls}`}>
      <span class={`w-1 h-1 rounded-full ${status === 'active' ? 'bg-success' : status === 'published' ? 'bg-accent' : 'bg-muted'}`}></span>
      {s.label}
    </span>
  </div>

  <p class="text-[11px] text-muted font-mono mb-2">{fullName}</p>
  <p class="text-xs text-[#94a3b8] leading-relaxed line-clamp-2 mb-3">{description}</p>

  <div class="flex flex-wrap gap-1.5">
    {tech.slice(0, 4).map((t: string) => (
      <span class="px-1.5 py-0.5 rounded text-[10px] font-mono bg-white/[0.03] text-muted border border-white/[0.04]">
        {t}
      </span>
    ))}
    {tech.length > 4 && (
      <span class="text-[10px] text-muted/50 font-mono">+{tech.length - 4}</span>
    )}
  </div>
</a>
