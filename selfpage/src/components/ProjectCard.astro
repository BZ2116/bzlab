---
interface Props {
  slug: string;
  name: string;
  fullName: string;
  type: string;
  description: string;
  tech: string[];
  status: string;
  featured?: boolean;
}

const { slug, name, fullName, type, description, tech, status, featured = false } = Astro.props;
---

<a href={`/projects/${slug}`} class={`project-card ${featured ? 'featured' : ''}`}>
  <div class="project-card-top">
    <span class="project-kind">{type}</span>
    <span class={`status ${status}`}>{status}</span>
  </div>
  <h3>{name}</h3>
  <p>{fullName}</p>
  <p>{description}</p>
  <div class="tag-list">
    {tech.slice(0, 5).map((item) => <span class="tag">{item}</span>)}
  </div>
</a>
