---
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile.json';
---

<BaseLayout title="Archive · Bruce Zhao">
  <section class="section page-hero">
    <p class="eyebrow">Archive</p>
    <h1 class="page-title">A quieter photo wall for the old homepage.</h1>
    <p class="lead">保留一点旧版主页的生活感，但视觉系统已经并入 v3.0。</p>
    <div class="button-row">
      <a class="button primary" href="/">Back Home</a>
      <a class="button" href={`mailto:${profile.contact.email}`}>Contact</a>
    </div>
  </section>

  <section class="section archive-photo-grid">
    <img src="/img/BZ/BZ1.jpg" alt="Bruce Zhao archive photo 1" />
    <img src="/img/BZ/BZ2.jpg" alt="Bruce Zhao archive photo 2" />
    <img src="/img/BZ/BZ3.jpg" alt="Bruce Zhao archive photo 3" />
  </section>
</BaseLayout>
