---
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile.json';
import { skills } from '../data/skills.json';
---

<BaseLayout title="技能 · Bruce Zhao" description="技术栈与研究方向">
  <section class="section page-hero">
    <p class="eyebrow">能力</p>
    <h1 class="page-title">技能与研究方向</h1>
    <p class="lead">{profile.title}</p>
  </section>

  <section class="section split">
    <div class="section-heading">
      <p class="eyebrow">技术栈</p>
      <h2>技能。</h2>
    </div>
    <div class="resume-list">
      {skills.map((group) => (
        <article class="resume-block">
          <h2>{group.category}</h2>
          <div class="tag-list">
            {group.items.map((item) => <span class="tag">{item}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section split">
    <div class="section-heading">
      <p class="eyebrow">方向</p>
      <h2>研究兴趣。</h2>
    </div>
    <div class="resume-list">
      <article class="resume-block">
        <div class="tag-list">
          {profile.research.map((item) => <span class="tag">{item}</span>)}
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
