---
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile.json';
import { projects } from '../data/projects.json';
import { skills } from '../data/skills.json';

const selected = projects.filter((project) => ['uavp', 'medrnet', 'note-forge'].includes(project.slug));
---

<BaseLayout title="Resume · Bruce Zhao" description={profile.title}>
  <section class="section page-hero">
    <p class="eyebrow">Resume</p>
    <h1 class="page-title">{profile.nameEn}</h1>
    <p class="lead">{profile.title}</p>
    <div class="button-row">
      <a class="button primary" href={`mailto:${profile.contact.email}`}>{profile.contact.email}</a>
      <a class="button" href={profile.contact.github} target="_blank" rel="noopener noreferrer">github.com/{profile.contact.githubUser}</a>
    </div>
  </section>

  <section class="section split">
    <div class="section-heading">
      <p class="eyebrow">Profile</p>
      <h2>AI engineering with a research backbone.</h2>
      <p>{profile.bio}</p>
    </div>
    <div class="resume-list">
      <article class="resume-block">
        <h2>Education</h2>
        {profile.education.map((item) => (
          <div class="resume-row">
            <time>{item.period}</time>
            <div>
              <h3>{item.school}</h3>
              <p>{item.degree}</p>
              <p>{item.note}</p>
            </div>
          </div>
        ))}
      </article>

      <article class="resume-block">
        <h2>Selected Projects</h2>
        {selected.map((project) => (
          <div class="resume-row">
            <span>{project.status}</span>
            <div>
              <h3><a href={`/projects/${project.slug}`}>{project.name}</a></h3>
              <p>{project.description}</p>
              <div class="tag-list" style="margin-top: .7rem;">
                {project.tech.slice(0, 5).map((item) => <span class="tag">{item}</span>)}
              </div>
            </div>
          </div>
        ))}
      </article>

      <article class="resume-block">
        <h2>Skills</h2>
        {skills.map((group) => (
          <div class="resume-row">
            <span>{group.category}</span>
            <div class="tag-list">
              {group.items.map((item) => <span class="tag">{item}</span>)}
            </div>
          </div>
        ))}
      </article>

      <article class="resume-block">
        <h2>Research Interests</h2>
        <div class="tag-list">
          {profile.research.map((item) => <span class="tag">{item}</span>)}
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  @media print {
    :global(.site-header),
    :global(.site-footer),
    :global(.grain),
    :global(body::before) {
      display: none !important;
    }
  }
</style>
