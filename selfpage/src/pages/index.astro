---
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile.json';
---

<BaseLayout title="BZ's Lab — 赵耀">
  <section class="home">
    <!-- 顶部名字区 -->
    <header class="hero animate-in">
      <h1 class="hero-name">
        <span class="zh">{profile.name}</span>
        <span class="en">{profile.nameEn}</span>
      </h1>
      <p class="hero-tagline">{profile.title}</p>
    </header>

    <!-- 三列信息块 -->
    <div class="content">
      <!-- 教育 -->
      <div class="info-block animate-in delay-1">
        <div class="block-label">Education</div>
        <h2 class="block-title">重庆邮电大学</h2>
        <p class="block-meta">2022 — 2026 · 软件工程</p>
        <p class="block-desc">本科阶段主要做 AI 和计算机视觉方向的研究，参与多个科研项目，发表论文。</p>
        <div class="tags">
          <span class="tag">Computer Vision</span>
          <span class="tag">Deep Learning</span>
          <span class="tag">UAVP</span>
          <span class="tag">MeDRNet</span>
        </div>
      </div>

      <!-- 研究方向 -->
      <div class="info-block animate-in delay-2">
        <div class="block-label">Research</div>
        <h2 class="block-title">CV & Security</h2>
        <p class="block-meta">Low-light · Detection · Multimodal</p>
        <p class="block-desc">探索计算机视觉和安全科学的交叉地带，做有实际影响力的研究。</p>
        <div class="tags">
          {profile.research.map(r => <span class="tag">{r}</span>)}
        </div>
      </div>

      <!-- 未来 -->
      <div class="info-block animate-in delay-3">
        <div class="block-label">Next</div>
        <h2 class="block-title">中国科学技术大学</h2>
        <p class="block-meta">2026 — · 网络空间安全</p>
        <p class="block-desc">研究生阶段将转向网络安全，继续深入 CV 和 AI 方向的研究。热爱 CTF 竞赛和新技术探索。</p>
        <div class="tags">
          <span class="tag">Cybersecurity</span>
          <span class="tag">CTF</span>
          <span class="tag">Binary</span>
        </div>
      </div>
    </div>

    <!-- 底部链接 -->
    <div class="footer-links animate-in delay-4">
      <a href="/projects" class="footer-link">Projects</a>
      <a href="/resume" class="footer-link">Resume</a>
      <a href="/classic" class="footer-link">Classic</a>
      <a href="https://github.com/bz2116" class="footer-link" target="_blank" rel="noopener">GitHub</a>
      <a href="mailto:bzy1621@outlook.com" class="footer-link">Email</a>
    </div>
  </section>
</BaseLayout>