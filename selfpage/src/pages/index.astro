---
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile.json';
import { projects } from '../data/projects.json';

const featured = projects.filter((p) => ['synerza', 'uavp', 'medrnet'].includes(p.slug));
---

<BaseLayout title="Bruce Zhao · BZ Lab v3.0" description={profile.bio}>
  <section class="section hero">
    <div class="hero-content">
      <div class="hero-top">
        <div class="hero-intro">
          <p class="eyebrow">个人研究主页</p>
          <h1 class="hero-title">{profile.nameEn}<br />{profile.name}</h1>
        </div>
        <aside class="panel hero-visual">
          <img src="/img/BZ/26_1寸.jpg" alt="Bruce Zhao portrait" />
          <div class="visual-caption">
            {profile.console.focus}<br />
            {profile.console.work}
          </div>
        </aside>
      </div>
      <p class="lead">{profile.bio}</p>
      <div class="button-row">
        <a class="button primary" href="/projects">查看项目</a>
        <a class="button" href="/resume">查看简历</a>
        <a class="button" href={profile.contact.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
      <div class="hero-meta" aria-label="Profile summary">
        <div>
          <span>当前</span>
          <strong>软件工程本科</strong>
        </div>
        <div>
          <span>研究</span>
          <strong>CV + VLM</strong>
        </div>
        <div>
          <span>下一阶段</span>
          <strong>网络安全</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section split">
    <div class="section-heading">
      <p class="eyebrow">代表项目</p>
      <h2>一些研究。</h2>
    </div>
    <div class="work-grid">
      {featured.map((project, index) => (
        <a href={`/projects/${project.slug}`} class={`project-card ${index === 0 ? 'featured' : ''}`}>
          <div class="project-card-top">
            <span class="project-kind">{project.type}</span>
            <span class={`status ${project.status}`}>{project.status}</span>
          </div>
          <h3>{project.name}</h3>
          <p>{project.description}</p>
          <div class="tag-list">
            {project.tech.slice(0, 5).map((tech) => <span class="tag">{tech}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section split">
    <div class="section-heading">
      <p class="eyebrow">成长轨迹</p>
      <h2>从软件到大模型。</h2>
    </div>
    <div class="timeline">
      {profile.education.map((item) => (
        <article class="panel timeline-item">
          <time>{item.period}</time>
          <div>
            <h3>{item.school}</h3>
            <p>{item.degree}</p>
            <p>{item.note}</p>
          </div>
        </article>
      ))}
      <article class="panel timeline-item">
        <time>当前</time>
        <div>
          <h3>研究兴趣</h3>
          <div class="tag-list">
            {profile.research.map((item) => <span class="tag">{item}</span>)}
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="section split">
    <div class="section-heading">
      <p class="eyebrow">亮点</p>
      <h2>代表性成果。</h2>
    </div>
    <div class="timeline">
      {profile.highlights.map((item, index) => (
        <article class="panel timeline-item">
          <time>{String(index + 1).padStart(2, '0')}</time>
          <div>
            <h3>{item}</h3>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
