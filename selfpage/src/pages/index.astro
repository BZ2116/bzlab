---
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile.json';
import { projects } from '../data/projects.json';

const featured = projects.slice(0, 3);
---

<BaseLayout title="Bruce Zhao · BZ Lab v3.0" description={profile.bio}>
  <section class="section hero">
    <div>
      <p class="eyebrow">Personal research homepage / v3.0</p>
      <h1 class="hero-title">{profile.nameEn}<br />{profile.name}</h1>
      <p class="lead">{profile.signature}</p>
      <p class="lead">{profile.bio}</p>
      <div class="button-row">
        <a class="button primary" href="/projects">View Projects</a>
        <a class="button" href="/resume">Open Resume</a>
        <a class="button" href={profile.contact.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
      <div class="hero-meta" aria-label="Profile summary">
        <div>
          <span>Current</span>
          <strong>Software Engineering</strong>
        </div>
        <div>
          <span>Research</span>
          <strong>Vision + VLM</strong>
        </div>
        <div>
          <span>Next</span>
          <strong>Cybersecurity</strong>
        </div>
      </div>
    </div>
    <aside class="panel hero-visual">
      <img src="/img/BZ/BZ11.jpg" alt="Bruce Zhao portrait and campus life" />
      <div class="visual-caption">
        {profile.console.focus}<br />
        {profile.console.work}
      </div>
    </aside>
  </section>

  <section class="section split">
    <div class="section-heading">
      <p class="eyebrow">Selected Work</p>
      <h2>Research that can be shipped.</h2>
      <p>把模型、实验、界面和文档连成完整闭环，是这个主页想呈现的核心能力。</p>
    </div>
    <div class="work-grid">
      {featured.map((project, index) => (
        <a href={`/projects/${project.slug}`} class={`project-card ${index === 0 ? 'featured' : ''}`}>
          <div class="project-card-top">
            <span class="project-kind">{project.type}</span>
            <span class={`status ${project.status}`}>{project.status}</span>
          </div>
          <h3>{project.name}</h3>
          <p>{project.description}</p>
          <div class="tag-list">
            {project.tech.slice(0, 5).map((tech) => <span class="tag">{tech}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section split">
    <div class="section-heading">
      <p class="eyebrow">Trajectory</p>
      <h2>From software engineering to trustworthy AI security.</h2>
    </div>
    <div class="timeline">
      {profile.education.map((item) => (
        <article class="panel timeline-item">
          <time>{item.period}</time>
          <div>
            <h3>{item.school}</h3>
            <p>{item.degree}</p>
            <p>{item.note}</p>
          </div>
        </article>
      ))}
      <article class="panel timeline-item">
        <time>Now</time>
        <div>
          <h3>Research interests</h3>
          <div class="tag-list">
            {profile.research.map((item) => <span class="tag">{item}</span>)}
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="section split">
    <div class="section-heading">
      <p class="eyebrow">Highlights</p>
      <h2>What I want people to remember.</h2>
    </div>
    <div class="timeline">
      {profile.highlights.map((item, index) => (
        <article class="panel timeline-item">
          <time>{String(index + 1).padStart(2, '0')}</time>
          <div>
            <h3>{item}</h3>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
